<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24127" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24063"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="MoreViewController">
            <connections>
                <outlet property="imgUserAvater" destination="img-avatar" id="avatar-conn"/>
                <outlet property="view" destination="main-view" id="view-conn"/>
                <outlet property="viewUserId" destination="lbl-userid" id="userid-conn"/>
                <outlet property="viewUserName" destination="lbl-username" id="username-conn"/>
                <outlet property="layoutQRCode" destination="layout-qrcode" id="qrcode-conn"/>
                <outlet property="btnStatus" destination="btn-status" id="status-conn"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="main-view">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <scrollView clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" showsHorizontalScrollIndicator="NO" translatesAutoresizingMaskIntoConstraints="NO" id="scroll-view">
                    <rect key="frame" x="0.0" y="59" width="393" height="759"/>
                    <subviews>
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="content-view">
                            <rect key="frame" x="0.0" y="0.0" width="393" height="500"/>
                            <subviews>

                                <!-- ========== 个人信息区域（全宽白色条带，无圆角） ========== -->
                                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="layout-profile">
                                    <rect key="frame" x="0" y="0" width="393" height="120"/>
                                    <subviews>
                                        <!-- 头像 (65x65 圆角方形) -->
                                        <imageView userInteractionEnabled="YES" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="default_avatar_60" translatesAutoresizingMaskIntoConstraints="NO" id="img-avatar">
                                            <rect key="frame" x="20" y="18" width="65" height="65"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="65" id="avatar-w"/>
                                                <constraint firstAttribute="height" constant="65" id="avatar-h"/>
                                            </constraints>
                                        </imageView>
                                        <!-- 用户名 -->
                                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Jack" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="lbl-username">
                                            <rect key="frame" x="100" y="20" width="200" height="24"/>
                                            <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="19"/>
                                            <color key="textColor" red="0.11" green="0.11" blue="0.12" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                        </label>
                                        <!-- Chat ID -->
                                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Chat ID: 400069" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="lbl-userid">
                                            <rect key="frame" x="100" y="48" width="200" height="18"/>
                                            <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                            <color key="textColor" red="0.6" green="0.61" blue="0.63" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                        </label>
                                        <!-- 个性签名：Chat ID 下方单行显示 -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="left" contentVerticalAlignment="center" lineBreakMode="tailTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-status">
                                            <rect key="frame" x="100" y="76" width="220" height="22"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="22" id="status-btn-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" pointSize="13"/>
                                            <inset key="contentEdgeInsets" minX="0" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="个性签名：暂无">
                                                <color key="titleColor" red="0.6" green="0.61" blue="0.63" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <connections>
                                                <action selector="gotoStatus:" destination="-1" eventType="touchUpInside" id="status-action"/>
                                            </connections>
                                        </button>
                                        <!-- 二维码图标 (右侧，箭头上方；点击区域 44x44，图标 16x16 居中) -->
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="layout-qrcode">
                                            <rect key="frame" x="350" y="26" width="64" height="64"/>
                                            <subviews>
                                                <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="qr" translatesAutoresizingMaskIntoConstraints="NO" id="qr-icon">
                                                    <rect key="frame" x="14" y="14" width="16" height="16"/>
                                                    <constraints>
                                                        <constraint firstAttribute="width" constant="16" id="qr-w"/>
                                                        <constraint firstAttribute="height" constant="16" id="qr-h"/>
                                                    </constraints>
                                                </imageView>
                                            </subviews>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="44" id="qr-layout-w"/>
                                                <constraint firstAttribute="height" constant="44" id="qr-layout-h"/>
                                                <constraint firstItem="qr-icon" firstAttribute="centerX" secondItem="layout-qrcode" secondAttribute="centerX" id="qr-icon-cx"/>
                                                <constraint firstItem="qr-icon" firstAttribute="centerY" secondItem="layout-qrcode" secondAttribute="centerY" id="qr-icon-cy"/>
                                            </constraints>
                                        </view>
                                        <!-- 右侧箭头 ">"（二维码下方） -->
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="profile-arrow">
                                            <rect key="frame" x="366" y="60" width="8" height="14"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="8" id="pa-w"/>
                                                <constraint firstAttribute="height" constant="14" id="pa-h"/>
                                            </constraints>
                                        </imageView>
                                        <!-- 整个区域的点击按钮（透明覆盖） -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-profile">
                                            <rect key="frame" x="0" y="0" width="393" height="120"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <connections>
                                                <action selector="gotoMyProfile:" destination="-1" eventType="touchUpInside" id="profile-action"/>
                                            </connections>
                                        </button>
                                    </subviews>
                                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <!-- 头像 -->
                                        <constraint firstItem="img-avatar" firstAttribute="leading" secondItem="layout-profile" secondAttribute="leading" constant="20" id="avatar-l"/>
                                        <constraint firstItem="img-avatar" firstAttribute="top" secondItem="layout-profile" secondAttribute="top" constant="18" id="avatar-top"/>
                                        <!-- 用户名 -->
                                        <constraint firstItem="lbl-username" firstAttribute="leading" secondItem="img-avatar" secondAttribute="trailing" constant="15" id="name-l"/>
                                        <constraint firstItem="lbl-username" firstAttribute="top" secondItem="img-avatar" secondAttribute="top" constant="2" id="name-t"/>
                                        <!-- Chat ID -->
                                        <constraint firstItem="lbl-userid" firstAttribute="leading" secondItem="lbl-username" secondAttribute="leading" id="id-l"/>
                                        <constraint firstItem="lbl-userid" firstAttribute="top" secondItem="lbl-username" secondAttribute="bottom" constant="4" id="id-t"/>
                                        <!-- 个性签名：Chat ID 下方单行 -->
                                        <constraint firstItem="btn-status" firstAttribute="leading" secondItem="lbl-username" secondAttribute="leading" id="status-l"/>
                                        <constraint firstItem="btn-status" firstAttribute="top" secondItem="lbl-userid" secondAttribute="bottom" constant="8" id="status-t"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-status" secondAttribute="trailing" constant="60" id="status-r"/>
                                        <!-- 个人信息区域底部 -->
                                        <constraint firstItem="btn-status" firstAttribute="bottom" secondItem="layout-profile" secondAttribute="bottom" constant="-16" id="status-bot"/>
                                        <constraint firstAttribute="height" relation="greaterThanOrEqual" constant="120" id="profile-h"/>
                                        <!-- 二维码（右侧 44x44 点击区，与箭头同一水平居中偏上） -->
                                        <constraint firstAttribute="trailing" secondItem="layout-qrcode" secondAttribute="trailing" constant="20" id="qr-r"/>
                                        <constraint firstItem="layout-qrcode" firstAttribute="centerY" secondItem="layout-profile" secondAttribute="centerY" constant="-15" id="qr-bot"/>
                                        <!-- 右侧箭头（独立右侧定位，不随二维码移动） -->
                                        <constraint firstAttribute="trailing" secondItem="profile-arrow" secondAttribute="trailing" constant="15" id="pa-r"/>
                                        <constraint firstItem="profile-arrow" firstAttribute="top" secondItem="layout-profile" secondAttribute="centerY" constant="3" id="pa-top"/>
                                        <!-- 点击按钮 -->
                                        <constraint firstItem="btn-profile" firstAttribute="leading" secondItem="layout-profile" secondAttribute="leading" id="btn-l"/>
                                        <constraint firstItem="btn-profile" firstAttribute="trailing" secondItem="layout-profile" secondAttribute="trailing" id="btn-r"/>
                                        <constraint firstItem="btn-profile" firstAttribute="top" secondItem="layout-profile" secondAttribute="top" id="btn-t"/>
                                        <constraint firstItem="btn-profile" firstAttribute="bottom" secondItem="layout-profile" secondAttribute="bottom" id="btn-b"/>
                                    </constraints>
                                </view>

                                <!-- ========== 功能列表 分组1（全宽白色条带） ========== -->
                                <!-- 收藏、通话、朋友圈、消息通知、分享应用 -->
                                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="layout-features-1">
                                <rect key="frame" x="0" y="106" width="393" height="280"/>
                                    <subviews>
                                        <!-- ===== 行1: 收藏 ===== -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="leading" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-favorites">
                                            <rect key="frame" x="0" y="0" width="393" height="56"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="56" id="fav-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" weight="regular" pointSize="17"/>
                                            <inset key="contentEdgeInsets" minX="56" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="收藏">
                                                <color key="titleColor" red="0.1" green="0.1" blue="0.1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <state key="highlighted" backgroundImage="common_btn_hilight_bg"/>
                                            <connections>
                                                <action selector="gotoFavorites:" destination="-1" eventType="touchUpInside" id="fav-action"/>
                                            </connections>
                                        </button>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="sc" translatesAutoresizingMaskIntoConstraints="NO" id="fav-icon">
                                            <rect key="frame" x="20" y="17" width="22" height="22"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="22" id="fav-icon-w"/>
                                                <constraint firstAttribute="height" constant="22" id="fav-icon-h"/>
                                            </constraints>
                                        </imageView>
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="fav-arrow">
                                            <rect key="frame" x="369" y="21" width="8" height="14"/>
                                        </imageView>
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="fav-sep">
                                            <rect key="frame" x="56" y="55.5" width="337" height="0.5"/>
                                            <color key="backgroundColor" red="0.90" green="0.90" blue="0.90" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="0.5" id="fav-sep-h"/>
                                            </constraints>
                                        </view>

                                        <!-- ===== 行2: 朋友圈 ===== -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="leading" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-moments">
                                            <rect key="frame" x="0" y="56" width="393" height="56"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="56" id="mom-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" weight="regular" pointSize="17"/>
                                            <inset key="contentEdgeInsets" minX="56" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="朋友圈">
                                                <color key="titleColor" red="0.1" green="0.1" blue="0.1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <state key="highlighted" backgroundImage="common_btn_hilight_bg"/>
                                            <connections>
                                                <action selector="gotoMoments:" destination="-1" eventType="touchUpInside" id="mom-action"/>
                                            </connections>
                                        </button>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="pyq" translatesAutoresizingMaskIntoConstraints="NO" id="mom-icon">
                                            <rect key="frame" x="20" y="73" width="22" height="22"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="22" id="mom-icon-w"/>
                                                <constraint firstAttribute="height" constant="22" id="mom-icon-h"/>
                                            </constraints>
                                        </imageView>
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="mom-arrow">
                                            <rect key="frame" x="369" y="77" width="8" height="14"/>
                                        </imageView>
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="mom-sep">
                                            <rect key="frame" x="56" y="111.5" width="337" height="0.5"/>
                                            <color key="backgroundColor" red="0.90" green="0.90" blue="0.90" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="0.5" id="mom-sep-h"/>
                                            </constraints>
                                        </view>

                                        <!-- ===== 行3: 消息通知 ===== -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="leading" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-photos">
                                            <rect key="frame" x="0" y="112" width="393" height="56"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="56" id="pht-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" weight="regular" pointSize="17"/>
                                            <inset key="contentEdgeInsets" minX="56" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="消息通知">
                                                <color key="titleColor" red="0.1" green="0.1" blue="0.1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <state key="highlighted" backgroundImage="common_btn_hilight_bg"/>
                                            <connections>
                                                <action selector="gotoNotification:" destination="-1" eventType="touchUpInside" id="pht-action"/>
                                            </connections>
                                        </button>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="more_notification_icon" translatesAutoresizingMaskIntoConstraints="NO" id="pht-icon">
                                            <rect key="frame" x="20" y="129" width="22" height="22"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="22" id="pht-icon-w"/>
                                                <constraint firstAttribute="height" constant="22" id="pht-icon-h"/>
                                            </constraints>
                                        </imageView>
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="pht-arrow">
                                            <rect key="frame" x="369" y="133" width="8" height="14"/>
                                        </imageView>
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="pht-sep">
                                            <rect key="frame" x="56" y="167.5" width="337" height="0.5"/>
                                            <color key="backgroundColor" red="0.90" green="0.90" blue="0.90" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="0.5" id="pht-sep-h"/>
                                            </constraints>
                                        </view>

                                        <!-- ===== 行4: 分享应用 ===== -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="leading" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-share">
                                            <rect key="frame" x="0" y="168" width="393" height="56"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="56" id="share-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" weight="regular" pointSize="17"/>
                                            <inset key="contentEdgeInsets" minX="56" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="分享应用">
                                                <color key="titleColor" red="0.1" green="0.1" blue="0.1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <state key="highlighted" backgroundImage="common_btn_hilight_bg"/>
                                            <connections>
                                                <action selector="gotoShareApp:" destination="-1" eventType="touchUpInside" id="share-action"/>
                                            </connections>
                                        </button>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="more_share_app_icon" translatesAutoresizingMaskIntoConstraints="NO" id="share-icon">
                                            <constraints>
                                                <constraint firstAttribute="width" constant="22" id="share-icon-w"/>
                                                <constraint firstAttribute="height" constant="22" id="share-icon-h"/>
                                            </constraints>
                                        </imageView>
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="share-arrow"/>
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="share-sep">
                                            <rect key="frame" x="56" y="223.5" width="337" height="0.5"/>
                                            <color key="backgroundColor" red="0.90" green="0.90" blue="0.90" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="0.5" id="share-sep-h"/>
                                            </constraints>
                                        </view>

                                        <!-- ===== 行5: 通话 ===== -->
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="leading" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-calls">
                                            <rect key="frame" x="0" y="224" width="393" height="56"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="56" id="call-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" weight="regular" pointSize="17"/>
                                            <inset key="contentEdgeInsets" minX="56" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="通话">
                                                <color key="titleColor" red="0.1" green="0.1" blue="0.1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <state key="highlighted" backgroundImage="common_btn_hilight_bg"/>
                                            <connections>
                                                <action selector="gotoCalls:" destination="-1" eventType="touchUpInside" id="call-action"/>
                                            </connections>
                                        </button>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="more_calls_icon" translatesAutoresizingMaskIntoConstraints="NO" id="call-icon">
                                            <rect key="frame" x="20" y="241" width="22" height="22"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="22" id="call-icon-w"/>
                                                <constraint firstAttribute="height" constant="22" id="call-icon-h"/>
                                            </constraints>
                                        </imageView>
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="call-arrow">
                                            <rect key="frame" x="369" y="245" width="8" height="14"/>
                                        </imageView>
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="call-sep">
                                            <rect key="frame" x="56" y="279.5" width="337" height="0.5"/>
                                            <color key="backgroundColor" red="0.90" green="0.90" blue="0.90" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="0.5" id="call-sep-h"/>
                                            </constraints>
                                        </view>

                                    </subviews>
                                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <constraint firstAttribute="height" constant="280" id="s1-h"/>
                                        <!-- 行1: 收藏 -->
                                        <constraint firstItem="btn-favorites" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" id="fav-btn-l"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-favorites" secondAttribute="trailing" id="fav-btn-r"/>
                                        <constraint firstItem="btn-favorites" firstAttribute="top" secondItem="layout-features-1" secondAttribute="top" id="fav-btn-t"/>
                                        <constraint firstItem="fav-icon" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="20" id="fav-icon-l"/>
                                        <constraint firstItem="fav-icon" firstAttribute="centerY" secondItem="btn-favorites" secondAttribute="centerY" id="fav-icon-cy"/>
                                        <constraint firstAttribute="trailing" secondItem="fav-arrow" secondAttribute="trailing" constant="16" id="fav-arrow-r"/>
                                        <constraint firstItem="fav-arrow" firstAttribute="centerY" secondItem="btn-favorites" secondAttribute="centerY" id="fav-arrow-cy"/>
                                        <constraint firstItem="fav-sep" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="56" id="fav-sep-l"/>
                                        <constraint firstAttribute="trailing" secondItem="fav-sep" secondAttribute="trailing" id="fav-sep-r"/>
                                        <constraint firstItem="fav-sep" firstAttribute="top" secondItem="btn-favorites" secondAttribute="bottom" constant="-0.5" id="fav-sep-t"/>
                                        <!-- 行2: 通话 -->
                                        <constraint firstItem="btn-calls" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" id="call-btn-l"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-calls" secondAttribute="trailing" id="call-btn-r"/>
                                        <constraint firstItem="btn-calls" firstAttribute="top" secondItem="btn-favorites" secondAttribute="bottom" id="call-btn-t"/>
                                        <!-- 行3: 朋友圈 -->
                                        <constraint firstItem="btn-moments" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" id="mom-btn-l"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-moments" secondAttribute="trailing" id="mom-btn-r"/>
                                        <constraint firstItem="btn-moments" firstAttribute="top" secondItem="btn-calls" secondAttribute="bottom" id="mom-btn-t"/>
                                        <constraint firstItem="mom-icon" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="20" id="mom-icon-l"/>
                                        <constraint firstItem="mom-icon" firstAttribute="centerY" secondItem="btn-moments" secondAttribute="centerY" id="mom-icon-cy"/>
                                        <constraint firstAttribute="trailing" secondItem="mom-arrow" secondAttribute="trailing" constant="16" id="mom-arrow-r"/>
                                        <constraint firstItem="mom-arrow" firstAttribute="centerY" secondItem="btn-moments" secondAttribute="centerY" id="mom-arrow-cy"/>
                                        <constraint firstItem="mom-sep" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="56" id="mom-sep-l"/>
                                        <constraint firstAttribute="trailing" secondItem="mom-sep" secondAttribute="trailing" id="mom-sep-r"/>
                                        <constraint firstItem="mom-sep" firstAttribute="top" secondItem="btn-moments" secondAttribute="bottom" constant="-0.5" id="mom-sep-t"/>
                                        <!-- 行4: 消息通知 -->
                                        <constraint firstItem="btn-photos" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" id="pht-btn-l"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-photos" secondAttribute="trailing" id="pht-btn-r"/>
                                        <constraint firstItem="btn-photos" firstAttribute="top" secondItem="btn-moments" secondAttribute="bottom" id="pht-btn-t"/>
                                        <constraint firstItem="pht-icon" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="20" id="pht-icon-l"/>
                                        <constraint firstItem="pht-icon" firstAttribute="centerY" secondItem="btn-photos" secondAttribute="centerY" id="pht-icon-cy"/>
                                        <constraint firstAttribute="trailing" secondItem="pht-arrow" secondAttribute="trailing" constant="16" id="pht-arrow-r"/>
                                        <constraint firstItem="pht-arrow" firstAttribute="centerY" secondItem="btn-photos" secondAttribute="centerY" id="pht-arrow-cy"/>
                                        <constraint firstItem="pht-sep" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="56" id="pht-sep-l"/>
                                        <constraint firstAttribute="trailing" secondItem="pht-sep" secondAttribute="trailing" id="pht-sep-r"/>
                                        <constraint firstItem="pht-sep" firstAttribute="top" secondItem="btn-photos" secondAttribute="bottom" constant="-0.5" id="pht-sep-t"/>
                                        <!-- 行5: 分享应用 -->
                                        <constraint firstItem="btn-share" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" id="share-btn-l"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-share" secondAttribute="trailing" id="share-btn-r"/>
                                        <constraint firstItem="btn-share" firstAttribute="top" secondItem="btn-photos" secondAttribute="bottom" id="share-btn-t"/>
                                        <constraint firstItem="share-icon" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="20" id="share-icon-l"/>
                                        <constraint firstItem="share-icon" firstAttribute="centerY" secondItem="btn-share" secondAttribute="centerY" id="share-icon-cy"/>
                                        <constraint firstAttribute="trailing" secondItem="share-arrow" secondAttribute="trailing" constant="16" id="share-arrow-r"/>
                                        <constraint firstItem="share-arrow" firstAttribute="centerY" secondItem="btn-share" secondAttribute="centerY" id="share-arrow-cy"/>
                                        <constraint firstItem="share-sep" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="56" id="share-sep-l"/>
                                        <constraint firstAttribute="trailing" secondItem="share-sep" secondAttribute="trailing" id="share-sep-r"/>
                                        <constraint firstItem="share-sep" firstAttribute="top" secondItem="btn-share" secondAttribute="bottom" constant="-0.5" id="share-sep-t"/>
                                        <constraint firstItem="call-icon" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="20" id="call-icon-l"/>
                                        <constraint firstItem="call-icon" firstAttribute="centerY" secondItem="btn-calls" secondAttribute="centerY" id="call-icon-cy"/>
                                        <constraint firstAttribute="trailing" secondItem="call-arrow" secondAttribute="trailing" constant="16" id="call-arrow-r"/>
                                        <constraint firstItem="call-arrow" firstAttribute="centerY" secondItem="btn-calls" secondAttribute="centerY" id="call-arrow-cy"/>
                                        <constraint firstItem="call-sep" firstAttribute="leading" secondItem="layout-features-1" secondAttribute="leading" constant="56" id="call-sep-l"/>
                                        <constraint firstAttribute="trailing" secondItem="call-sep" secondAttribute="trailing" id="call-sep-r"/>
                                        <constraint firstItem="call-sep" firstAttribute="top" secondItem="btn-calls" secondAttribute="bottom" constant="-0.5" id="call-sep-t"/>
                                    </constraints>
                                </view>

                                <!-- ========== 功能列表 分组2（全宽白色条带） ========== -->
                                <!-- 设置 -->
                                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="layout-features-2">
                                    <rect key="frame" x="0" y="396" width="393" height="56"/>
                                    <subviews>
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="leading" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="btn-settings">
                                            <rect key="frame" x="0" y="0" width="393" height="56"/>
                                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <constraints>
                                                <constraint firstAttribute="height" constant="56" id="stt-h"/>
                                            </constraints>
                                            <fontDescription key="fontDescription" type="system" weight="regular" pointSize="17"/>
                                            <inset key="contentEdgeInsets" minX="56" minY="0" maxX="0" maxY="0"/>
                                            <state key="normal" title="设置">
                                                <color key="titleColor" red="0.1" green="0.1" blue="0.1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                            </state>
                                            <state key="highlighted" backgroundImage="common_btn_hilight_bg"/>
                                            <connections>
                                                <action selector="gotoSettings:" destination="-1" eventType="touchUpInside" id="stt-action"/>
                                            </connections>
                                        </button>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="set" translatesAutoresizingMaskIntoConstraints="NO" id="stt-icon">
                                            <rect key="frame" x="20" y="17" width="22" height="22"/>
                                            <constraints>
                                                <constraint firstAttribute="width" constant="22" id="stt-icon-w"/>
                                                <constraint firstAttribute="height" constant="22" id="stt-icon-h"/>
                                            </constraints>
                                        </imageView>
                                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="common_list_rightarrow_icon_nor" translatesAutoresizingMaskIntoConstraints="NO" id="stt-arrow">
                                            <rect key="frame" x="369" y="21" width="8" height="14"/>
                                        </imageView>
                                    </subviews>
                                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <constraint firstAttribute="height" constant="56" id="s2-h"/>
                                        <constraint firstItem="btn-settings" firstAttribute="leading" secondItem="layout-features-2" secondAttribute="leading" id="stt-btn-l"/>
                                        <constraint firstAttribute="trailing" secondItem="btn-settings" secondAttribute="trailing" id="stt-btn-r"/>
                                        <constraint firstItem="btn-settings" firstAttribute="top" secondItem="layout-features-2" secondAttribute="top" id="stt-btn-t"/>
                                        <constraint firstItem="stt-icon" firstAttribute="leading" secondItem="layout-features-2" secondAttribute="leading" constant="20" id="stt-icon-l"/>
                                        <constraint firstItem="stt-icon" firstAttribute="centerY" secondItem="btn-settings" secondAttribute="centerY" id="stt-icon-cy"/>
                                        <constraint firstAttribute="trailing" secondItem="stt-arrow" secondAttribute="trailing" constant="16" id="stt-arrow-r"/>
                                        <constraint firstItem="stt-arrow" firstAttribute="centerY" secondItem="btn-settings" secondAttribute="centerY" id="stt-arrow-cy"/>
                                    </constraints>
                                </view>

                            </subviews>
                            <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            <constraints>
                                <constraint firstAttribute="width" secondItem="scroll-view" secondAttribute="width" id="content-w"/>
                                <constraint firstAttribute="height" constant="476" id="content-h"/>
                                <!-- 个人信息区域：全宽，顶部对齐 -->
                                <constraint firstItem="layout-profile" firstAttribute="leading" secondItem="content-view" secondAttribute="leading" id="profile-l"/>
                                <constraint firstAttribute="trailing" secondItem="layout-profile" secondAttribute="trailing" id="profile-r"/>
                                <constraint firstItem="layout-profile" firstAttribute="top" secondItem="content-view" secondAttribute="top" id="profile-t"/>
                                <!-- 功能分组1：全宽，与个人信息区域间隔10pt -->
                                <constraint firstItem="layout-features-1" firstAttribute="leading" secondItem="content-view" secondAttribute="leading" id="s1-l"/>
                                <constraint firstAttribute="trailing" secondItem="layout-features-1" secondAttribute="trailing" id="s1-r"/>
                                <constraint firstItem="layout-features-1" firstAttribute="top" secondItem="layout-profile" secondAttribute="bottom" constant="10" id="s1-t"/>
                                <!-- 功能分组2：全宽，与分组1间隔10pt -->
                                <constraint firstItem="layout-features-2" firstAttribute="leading" secondItem="content-view" secondAttribute="leading" id="s2-l"/>
                                <constraint firstAttribute="trailing" secondItem="layout-features-2" secondAttribute="trailing" id="s2-r"/>
                                <constraint firstItem="layout-features-2" firstAttribute="top" secondItem="layout-features-1" secondAttribute="bottom" constant="10" id="s2-t"/>
                            </constraints>
                        </view>
                    </subviews>
                    <color key="backgroundColor" white="0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <constraints>
                        <constraint firstItem="content-view" firstAttribute="leading" secondItem="scroll-view" secondAttribute="leading" id="scroll-l"/>
                        <constraint firstItem="content-view" firstAttribute="trailing" secondItem="scroll-view" secondAttribute="trailing" id="scroll-r"/>
                        <constraint firstItem="content-view" firstAttribute="top" secondItem="scroll-view" secondAttribute="top" id="scroll-t"/>
                        <constraint firstItem="content-view" firstAttribute="bottom" secondItem="scroll-view" secondAttribute="bottom" id="scroll-b"/>
                    </constraints>
                </scrollView>
            </subviews>
            <viewLayoutGuide key="safeArea" id="safe-area"/>
            <color key="backgroundColor" red="0.941" green="0.941" blue="0.941" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <constraints>
                <constraint firstItem="scroll-view" firstAttribute="leading" secondItem="safe-area" secondAttribute="leading" id="sv-l"/>
                <constraint firstItem="scroll-view" firstAttribute="trailing" secondItem="safe-area" secondAttribute="trailing" id="sv-r"/>
                <constraint firstItem="scroll-view" firstAttribute="top" secondItem="safe-area" secondAttribute="top" id="sv-t"/>
                <constraint firstItem="scroll-view" firstAttribute="bottom" secondItem="safe-area" secondAttribute="bottom" id="sv-b"/>
            </constraints>
        </view>
    </objects>
